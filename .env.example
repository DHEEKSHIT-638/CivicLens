# Google AI Studio (Gemini 2.5 API Key)
# Get yours at: https://aistudio.google.com/
VITE_GEMINI_API_KEY=


# OpenWeatherMap API Key (for 5-day weather decay forecast telemetry)
# Get yours at: https://openweathermap.org/
VITE_OPENWEATHERMAP_API_KEY=

# Firebase Web Application configuration settings
# Register a web app in your Firebase project to get these parameters.
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
